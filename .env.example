# ============================================
# Переменные окружения для Render
# ============================================

# Приложение
APP_DEBUG=false
APP_TIMEZONE=UTC
LOG_LEVEL=info

# База данных (MySQL)
# Значения копируйте из вашего MySQL-хостинга
DB_DRIVER=mysql
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=cms_bd
DB_USER=cms_user
DB_PASSWORD=your-password

# Сессия
SESSION_SECURE=true
