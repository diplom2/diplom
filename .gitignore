# .gitignore

# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
.AppleDouble
.LSOverride

# Dependency dirs
vendor/
node_modules/

# Logs
storage/logs/*.log
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Backups
storage/backups/*
*.bak
*.sql

# Uploaded files
public/uploads/*
!public/uploads/.gitkeep

# Composer
composer.lock

# Build artifacts
dist/
build/

# Test coverage
coverage/
.coverage

# Temporary files
tmp/
temp/

# Session files
sessions/*
!sessions/.gitkeep
